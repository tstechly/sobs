{% extends "base.html" %}
{% block title %}{{ dashboard.name }}{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1">
        <li class="breadcrumb-item"><a href="{{ url_for('list_dashboards') }}">Dashboards</a></li>
        <li class="breadcrumb-item active">{{ dashboard.name }}</li>
      </ol>
    </nav>
    <h4 class="fw-semibold mb-0">{{ dashboard.name }}</h4>
    {% if dashboard.description %}
    <p class="text-secondary small mb-0">{{ dashboard.description }}</p>
    {% endif %}
  </div>
  <div class="d-flex gap-2">
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addChartModal">
      <i class="bi bi-plus-lg me-1"></i>Add Chart
    </button>
    <form method="post" action="{{ url_for('delete_dashboard', dashboard_id=dashboard.id) }}"
          onsubmit="return confirm('Delete this dashboard and all its charts?')">
      <button type="submit" class="btn btn-outline-danger btn-sm">
        <i class="bi bi-trash me-1"></i>Delete
      </button>
    </form>
  </div>
</div>

{% if charts %}
<div class="row g-3" id="charts-container">
  {% for chart in charts %}
  <div class="col-lg-6" id="chart-card-{{ chart.id }}">
    <div class="card border-secondary">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-bar-chart me-1 text-primary"></i>{{ chart.title }}</span>
        <div class="d-flex gap-2 align-items-center">
          <span class="badge bg-secondary text-capitalize">{{ chart.chart_type }}</span>
          <form method="post"
                action="{{ url_for('remove_chart', dashboard_id=dashboard.id, chart_id=chart.id) }}"
                onsubmit="return confirm('Remove this chart?')">
            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1">
              <i class="bi bi-x"></i>
            </button>
          </form>
        </div>
      </div>
      <div class="card-body p-2">
        <div id="chart-{{ chart.id }}" style="height:300px;width:100%;"></div>
        <details class="mt-2">
          <summary class="text-secondary small" style="cursor:pointer;">SQL Query</summary>
          <pre class="small mt-1 p-2 bg-dark rounded text-secondary" style="max-height:120px;overflow:auto;">{{ chart.query }}</pre>
        </details>
      </div>
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<div class="text-center py-5 text-secondary">
  <i class="bi bi-bar-chart fs-1 d-block mb-3"></i>
  <p class="mb-3">No charts yet. Add your first chart to this dashboard.</p>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addChartModal">
    <i class="bi bi-plus-lg me-1"></i>Add Chart
  </button>
</div>
{% endif %}

<!-- Add Chart Modal -->
<div class="modal fade" id="addChartModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form method="post" action="{{ url_for('add_chart', dashboard_id=dashboard.id) }}">
        <div class="modal-header">
          <h5 class="modal-title">Add Chart</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Title <span class="text-danger">*</span></label>
            <input type="text" name="title" class="form-control" placeholder="e.g. Logs per Hour" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Chart Type</label>
            <select name="chart_type" class="form-select">
              {% for ct in chart_types %}
              <option value="{{ ct }}" {% if ct == 'bar' %}selected{% endif %}>{{ ct | capitalize }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">
              ClickHouse SQL Query <span class="text-danger">*</span>
              <small class="text-secondary ms-1">(SELECT only · max 1000 rows)</small>
            </label>
            <textarea name="query" class="form-control font-monospace" rows="5"
                      placeholder="SELECT toStartOfHour(Timestamp) AS hour, COUNT(*) AS cnt FROM otel_logs GROUP BY hour ORDER BY hour"
                      required></textarea>
            <div class="form-text">
              First column is used as the X-axis (or labels for pie charts); remaining columns are series values.
            </div>
          </div>
          <div class="mb-3" id="queryPreviewArea" style="display:none;">
            <label class="form-label">Query Preview</label>
            <div id="queryPreviewMsg" class="text-secondary small mb-2"></div>
            <div id="queryPreviewChart" style="height:200px;"></div>
          </div>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="previewBtn">
              <i class="bi bi-eye me-1"></i>Preview
            </button>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Chart</button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="{{ url_for('static', filename='echarts.min.js') }}"></script>
<script>
(function () {
  'use strict';

  var CHART_DATA = {{ charts | tojson }};
  var queryUrl = {{ url_for('execute_chart_query') | tojson }};

  /* ── helpers ── */
  function buildOption(chartType, columns, rows) {
    if (!columns.length || !rows.length) {
      return { title: { text: 'No data', left: 'center', top: 'center', textStyle: { color: '#6c757d' } } };
    }
    var labels = rows.map(function (r) { return String(r[0]); });
    var series = [];
    for (var ci = 1; ci < columns.length; ci++) {
      var colName = columns[ci];
      var values = rows.map(function (r) { return r[ci]; });
      if (chartType === 'pie') {
        series.push({
          type: 'pie',
          name: colName,
          data: labels.map(function (l, i) { return { name: l, value: values[i] }; }),
          radius: '65%'
        });
      } else {
        var seriesType = chartType === 'area' ? 'line' : chartType;
        var entry = { type: seriesType, name: colName, data: values };
        if (chartType === 'area') { entry.areaStyle = {}; }
        series.push(entry);
      }
    }

    var isDark = true;
    var textColor = '#adb5bd';
    var lineColor = '#2d3035';

    var option = {
      backgroundColor: 'transparent',
      textStyle: { color: textColor },
      tooltip: { trigger: chartType === 'pie' ? 'item' : 'axis' },
      legend: { textStyle: { color: textColor }, top: 'bottom' },
      series: series
    };

    if (chartType !== 'pie') {
      option.xAxis = {
        type: 'category',
        data: labels,
        axisLine: { lineStyle: { color: lineColor } },
        axisLabel: { color: textColor, rotate: labels.length > 10 ? 30 : 0 },
        splitLine: { lineStyle: { color: lineColor } }
      };
      option.yAxis = {
        type: 'value',
        axisLine: { lineStyle: { color: lineColor } },
        axisLabel: { color: textColor },
        splitLine: { lineStyle: { color: lineColor } }
      };
      option.grid = { left: '3%', right: '4%', bottom: '15%', containLabel: true };
    }
    return option;
  }

  function renderChart(chartCfg) {
    var el = document.getElementById('chart-' + chartCfg.id);
    if (!el) return;
    var ec = echarts.init(el, 'dark');
    ec.showLoading({ text: 'Loading…', color: '#0d6efd', textColor: '#adb5bd', maskColor: 'rgba(0,0,0,0.3)' });

    fetch(queryUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: chartCfg.query })
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        ec.hideLoading();
        if (data.error) {
          ec.setOption({ title: { text: 'Error: ' + data.error, left: 'center', top: 'center', textStyle: { color: '#dc3545', fontSize: 12 } } });
          return;
        }
        ec.setOption(buildOption(chartCfg.chart_type, data.columns, data.rows));
      })
      .catch(function (err) {
        ec.hideLoading();
        ec.setOption({ title: { text: 'Network error', left: 'center', top: 'center', textStyle: { color: '#dc3545' } } });
      });

    window.addEventListener('resize', function () { ec.resize(); });
  }

  /* ── render all dashboard charts ── */
  CHART_DATA.forEach(renderChart);

  /* ── preview inside modal ── */
  var previewBtn = document.getElementById('previewBtn');
  var previewChartInst = null;
  if (previewBtn) {
    previewBtn.addEventListener('click', function () {
      var modal = document.getElementById('addChartModal');
      var query = modal.querySelector('[name="query"]').value.trim();
      var chartType = modal.querySelector('[name="chart_type"]').value;
      var area = document.getElementById('queryPreviewArea');
      var msg = document.getElementById('queryPreviewMsg');
      area.style.display = 'block';
      msg.textContent = 'Running query…';
      if (previewChartInst) { previewChartInst.dispose(); previewChartInst = null; }

      fetch(queryUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: query })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.error) {
            msg.textContent = 'Error: ' + data.error;
            return;
          }
          msg.textContent = data.rows.length + ' row(s) returned';
          var el = document.getElementById('queryPreviewChart');
          previewChartInst = echarts.init(el, 'dark');
          previewChartInst.setOption(buildOption(chartType, data.columns, data.rows));
        })
        .catch(function (err) {
          msg.textContent = 'Network error: ' + err;
        });
    });
  }
})();
</script>
{% endblock %}
