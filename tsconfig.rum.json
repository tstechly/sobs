{
  "compilerOptions": {
    "target": "ES5",
    "ignoreDeprecations": "6.0",
    "lib": ["ES5", "ES2015", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "typeRoots": []
  },
  "include": ["static/rum.d.ts", "types/rum-globals.d.ts"],
  "exclude": ["node_modules"]
}
